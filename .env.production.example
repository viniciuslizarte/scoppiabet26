# Supabase + Vercel production variables.
# Do not commit real secrets. Copy values into Vercel Project Settings > Environment Variables.

# Prisma Client should use Supabase pooler/pooled connection in serverless deployments.
# Supabase docs recommend using the Transaction Pooler for serverless/autoscaling runtimes.
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"

# Prisma migrations should use the direct connection string.
DIRECT_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres"

# Generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-strong-secret"
NEXTAUTH_SECRET="replace-with-same-strong-secret"

# Production URL after Vercel deploy.
NEXTAUTH_URL="https://your-project.vercel.app"

# The only email allowed to use admin routes.
ADMIN_EMAIL="admin@scoppiabet.com"
